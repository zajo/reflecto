{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Meson build directories",
            "type": "shell",
            "command": "cd ${workspaceRoot} && meson setup _bld/debug && meson setup -D reflecto_single_header=true _bld/debug_single_header && meson setup _bld/release --buildtype release && meson setup -D reflecto_single_header=true _bld/release_single_header --buildtype release",
            "problemMatcher": []
        },
        {
            "label": "Generate reflecto.hpp",
            "type": "shell",
            "command": "cd ${workspaceRoot} && python scripts/generate_single_header.py -i include/boost/reflecto/detail/all.hpp -p ${workspaceRoot}/include -o ${workspaceRoot}/test/reflecto.hpp boost/reflecto",
            "problemMatcher": []
        },
        {
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "Build all unit tests (debug)",
            "type": "shell",
            "command": "cd ${workspaceRoot}/_bld/debug && ninja",
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}/_bld/debug"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "windows": {
                "problemMatcher": {
                    "owner": "msvc",
                    "fileLocation": [
                        "relative",
                        "${workspaceRoot}/_bld/debug"
                    ],
                    "pattern": {
                        "regexp": "^\\s*(?:\\d+>)?(.*)\\((\\d+(?:,\\d+)?)\\)\\s*:\\s+(error|warning|info)\\s+(\\w{1,2}\\d+)\\s*:\\s*(.*)$",
                        "file": 1,
                        "location": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            }
        },
        {
            "group": "test",
            "label": "Run all unit tests (debug)",
            "type": "shell",
            "dependsOn": [
                "Generate reflecto.hpp"
            ],
            "dependsOrder": "sequence",
            "command": "cd ${workspaceRoot}/_bld/debug && ninja && meson test && cd ${workspaceRoot}/_bld/debug_single_header && ninja && meson test",
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}/_bld/debug"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "windows": {
                "problemMatcher": {
                    "owner": "msvc",
                    "fileLocation": [
                        "relative",
                        "${workspaceRoot}/_bld/debug"
                    ],
                    "pattern": {
                        "regexp": "^\\s*(?:\\d+>)?(.*)\\((\\d+(?:,\\d+)?)\\)\\s*:\\s+(error|warning|info)\\s+(\\w{1,2}\\d+)\\s*:\\s*(.*)$",
                        "file": 1,
                        "location": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            }
        },
        {
            "group": "test",
            "label": "Run all unit tests (release)",
            "type": "shell",
            "dependsOn": [
                "Generate reflecto.hpp"
            ],
            "dependsOrder": "sequence",
            "command": "cd ${workspaceRoot}/_bld/release && ninja && meson test && cd ${workspaceRoot}/_bld/release_single_header && ninja && meson test",
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}/_bld/release"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "windows": {
                "problemMatcher": {
                    "owner": "msvc",
                    "fileLocation": [
                        "relative",
                        "${workspaceRoot}/_bld/release"
                    ],
                    "pattern": {
                        "regexp": "^\\s*(?:\\d+>)?(.*)\\((\\d+(?:,\\d+)?)\\)\\s*:\\s+(error|warning|info)\\s+(\\w{1,2}\\d+)\\s*:\\s*(.*)$",
                        "file": 1,
                        "location": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            }
        },
        {
            "group": "test",
            "label": "Run all unit tests (b2, all configurations)",
            "type": "shell",
            "dependsOn": [
                "Generate reflecto.hpp"
            ],
            "dependsOrder": "sequence",
            "command": "cd ${workspaceRoot}/test && b2 --abbreviate-paths variant=debug,release,reflecto_debug_single_header,reflecto_release_single_header cxxstd=11,14,17",
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}/_bld/release"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "windows": {
                "command": "cd ${workspaceRoot}\\test && b2 --abbreviate-paths variant=debug,release,reflecto_debug_single_header,reflecto_release_single_header cxxstd=14,17,latest",
                "problemMatcher": {
                    "owner": "msvc",
                    "fileLocation": [
                        "relative",
                        "${workspaceRoot}/_bld/release"
                    ],
                    "pattern": {
                        "regexp": "^\\s*(?:\\d+>)?(.*)\\((\\d+(?:,\\d+)?)\\)\\s*:\\s+(error|warning|info)\\s+(\\w{1,2}\\d+)\\s*:\\s*(.*)$",
                        "file": 1,
                        "location": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            }
        },
        {
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "label": "Test current editor file",
            "type": "shell",
            "command": "cd ${workspaceRoot}/_bld/debug && ninja && { meson test ${fileBasenameNoExtension} || cat ./meson-logs/testlog.txt; }",
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}/_bld/debug"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "windows": {
                "command": "cd ${workspaceRoot}/_bld/debug && ninja && (meson test ${fileBasenameNoExtension} || type .\\meson-logs\\testlog.txt)",
                "problemMatcher": {
                    "owner": "msvc",
                    "fileLocation": [
                        "relative",
                        "${workspaceRoot}/_bld/debug"
                    ],
                    "pattern": {
                        "regexp": "^\\s*(?:\\d+>)?(.*)\\((\\d+(?:,\\d+)?)\\)\\s*:\\s+(error|warning|info)\\s+(\\w{1,2}\\d+)\\s*:\\s*(.*)$",
                        "file": 1,
                        "location": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    }
                }
            }
        }
    ]
}
